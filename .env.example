# Public IP/host that HAProxy binds to and that appears in OIDC URLs.
# Defaults to the auto-detected current LAN address (set by ./setup.ps1).
# Use 0.0.0.0 to bind on all interfaces, or 127.0.0.1 for local-only.
HOST_IP=127.0.0.1

# Public port HAProxy listens on. Keycloak's hostname uses this too.
# 8080 (not 80) avoids privileged-port / Hyper-V reservation conflicts on Windows.
HOST_PORT=8080

# Keycloak admin (master realm only).
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# OAuth2 client secret (must match the realm-export.json secret).
OAUTH2_PROXY_CLIENT_SECRET=oauth2-proxy-secret

# Cookie signing secret. MUST be 16, 24, or 32 bytes.
# Generate with: openssl rand -hex 16
OAUTH2_PROXY_COOKIE_SECRET=0123456789abcdef0123456789abcdef
